{
  "name": "codex-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/client/index.js",
  "types": "dist/client/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./electron": {
      "types": "./dist/main/index.d.ts",
      "default": "./dist/main/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:python": "PYTHONPATH=python/src python3 -m unittest discover -s python/tests -p 'test_*.py'",
    "test:python:broker": "PYTHONPATH=broker/src python3 -m unittest discover -s broker/tests -p 'test_*.py'",
    "serve": "PYTHONPATH=broker/src python3 -m codex_bridge_broker serve",
    "login": "PYTHONPATH=broker/src python3 -m codex_bridge_broker login",
    "status": "PYTHONPATH=broker/src python3 -m codex_bridge_broker status",
    "models": "PYTHONPATH=broker/src python3 -m codex_bridge_broker models",
    "chat": "PYTHONPATH=broker/src python3 -m codex_bridge_broker chat",
    "package:broker": "python3 -m build broker",
    "package:sdk": "python3 -m build python",
    "serve:legacy": "node dist/cli/serve.js",
    "chat:legacy": "node dist/cli/chat-codex.js",
    "chat:codex": "npm run chat:legacy"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "electron": "^30.0.0",
    "typescript": "^5.7.2"
  }
}
